# Maestro Backend Configuration
# Copy to .env.local and fill in your values

# Set to true to disable auth entirely (dev/local mode)
# MAESTRO_AUTH_DISABLED=true

# Required — random string for JWT signing
# Generate with: openssl rand -hex 32
MAESTRO_SECRET=dev-secret-change-me

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=maestro
POSTGRES_USER=maestro
POSTGRES_PASSWORD=maestro

# Frontend URL — used for OAuth callback URI and post-login redirect.
# Must match the redirect URI registered in your OIDC provider.
MAESTRO_FRONTEND_URL=http://localhost:3000

# OIDC / SSO — works with any provider (Okta, Google, Azure AD, etc.)
# The callback URI registered in the IdP should be: {MAESTRO_FRONTEND_URL}/auth/callback
#
# Google:  https://accounts.google.com
# Okta:    https://your-org.okta.com/oauth2/<auth-server-id>
# Azure:   https://login.microsoftonline.com/<tenant-id>/v2.0
MAESTRO_OIDC_ISSUER=
MAESTRO_OIDC_CLIENT_ID=
MAESTRO_OIDC_CLIENT_SECRET=

# Optional — override scopes (default: "openid email profile")
# MAESTRO_OIDC_SCOPES=openid email profile

# Optional — explicit callback URL override (if your setup doesn't follow
# the standard {MAESTRO_FRONTEND_URL}/auth/callback pattern)
# MAESTRO_CALLBACK_URL=http://localhost:3000/auth/callback

# LLM provider
ANTHROPIC_API_KEY=

# Encryption key for stored tokens (Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAESTRO_ENCRYPTION_KEY=

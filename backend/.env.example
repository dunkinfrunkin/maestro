# Maestro Backend Configuration
# Copy to .env.local and fill in your values

# Required — random string for JWT signing
# Generate with: openssl rand -hex 32
MAESTRO_SECRET=dev-secret-change-me

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=maestro
POSTGRES_USER=maestro
POSTGRES_PASSWORD=maestro

# OIDC / SSO (optional — enables "Sign in with Google" etc.)
# Google: https://console.cloud.google.com/apis/credentials
MAESTRO_OIDC_ISSUER=https://accounts.google.com
MAESTRO_OIDC_CLIENT_ID=
MAESTRO_OIDC_CLIENT_SECRET=

# LLM provider
ANTHROPIC_API_KEY=

# Encryption key for stored tokens (Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAESTRO_ENCRYPTION_KEY=

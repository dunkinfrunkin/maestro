# Maestro Production Configuration
# Copy to .env and fill in your values:  cp .env.production.example .env

# Required — JWT signing secret
# Generate: openssl rand -hex 32
MAESTRO_SECRET=

# Required — Fernet encryption key for stored tokens
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAESTRO_ENCRYPTION_KEY=

# Database (defaults work with the bundled postgres)
POSTGRES_DB=maestro
POSTGRES_USER=maestro
POSTGRES_PASSWORD=maestro

# SSO / OIDC
# Google:  MAESTRO_OIDC_ISSUER=https://accounts.google.com
# Okta:    MAESTRO_OIDC_ISSUER=https://yourcompany.okta.com/oauth2/default
# Azure:   MAESTRO_OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
#
# Redirect URI to register with your IdP:
#   http://localhost:3000/api/v1/auth/callback
#   https://maestro.yourcompany.com/api/v1/auth/callback
MAESTRO_OIDC_ISSUER=
MAESTRO_OIDC_CLIENT_ID=
MAESTRO_OIDC_CLIENT_SECRET=

# Set to true to disable auth entirely (NOT recommended for production)
# MAESTRO_AUTH_DISABLED=true

# Anthropic API key (powers all agents)
ANTHROPIC_API_KEY=

# Port to expose (default 3000)
# PORT=3000
